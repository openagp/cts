{
  "agp_version": "0.1",
  "description": "Cross-language RFC 8785 JCS canonicalization test vectors. Implementations MUST produce identical canonical bytes for each input.",
  "vectors": [
    {
      "name": "key_ordering",
      "description": "Object keys MUST be sorted lexicographically.",
      "input": {
        "b": 2,
        "a": 1,
        "c": [
          3,
          2,
          1
        ],
        "_": "underscore"
      },
      "expected_canonical_utf8_hex": "7b225f223a22756e64657273636f7265222c2261223a312c2262223a322c2263223a5b332c322c315d7d",
      "expected_canonical_sha256_hex": "332365739eb5c765823a74b7634e6f87293a53cace6cd702a746d2c8c29db219"
    },
    {
      "name": "nested_objects",
      "description": "Nested object keys are also sorted.",
      "input": {
        "outer": {
          "z": 1,
          "a": 2
        },
        "alpha": {
          "y": [
            3,
            1,
            2
          ]
        }
      },
      "expected_canonical_utf8_hex": "7b22616c706861223a7b2279223a5b332c312c325d7d2c226f75746572223a7b2261223a322c227a223a317d7d",
      "expected_canonical_sha256_hex": "94ee94a023de8569e37c2938a1b5d9c6efe06f79a157adb8a245d021a65e5676"
    },
    {
      "name": "unicode_keys_and_strings",
      "description": "Unicode is preserved verbatim; sort order is by UTF-16 code unit.",
      "input": {
        "naïve": "café",
        "ascii": "plain",
        "数字": 42,
        "🚀": "rocket"
      },
      "expected_canonical_utf8_hex": "7b226173636969223a22706c61696e222c226e61c3af7665223a22636166c3a9222c22e695b0e5ad97223a34322c22f09f9a80223a22726f636b6574227d",
      "expected_canonical_sha256_hex": "38e90edf70600a29bd6ea788c963d79bd7bee9b743e1fc6636610281316c5b5a"
    },
    {
      "name": "numbers_integers_and_floats",
      "description": "Integers print without decimals; round-trip floats use shortest form.",
      "input": {
        "int": 42,
        "neg": -7,
        "float": 3.14,
        "zero": 0,
        "small": 0.5
      },
      "expected_canonical_utf8_hex": "7b22666c6f6174223a332e31342c22696e74223a34322c226e6567223a2d372c22736d616c6c223a302e352c227a65726f223a307d",
      "expected_canonical_sha256_hex": "efdfe0d6b40c921081df501165b0c77744dae90cda530cfd02b0644380b61a20"
    },
    {
      "name": "arrays_preserve_order",
      "description": "Array element order is preserved (only object keys sort).",
      "input": {
        "list": [
          3,
          1,
          4,
          1,
          5,
          9,
          2,
          6
        ]
      },
      "expected_canonical_utf8_hex": "7b226c697374223a5b332c312c342c312c352c392c322c365d7d",
      "expected_canonical_sha256_hex": "6fd81be77dfa1ed292496346a956e6a9f681ff7f775eebdf05f68088869ca1a0"
    },
    {
      "name": "empty_objects_and_arrays",
